---
import Hero from "@/sections/Hero.astro";
import Layout from "@/layouts/Layout.astro";
import AboutMe from "@/sections/AboutMe.astro";
import WorkExperience from "@/sections/WorkExperience.astro";
import Bento from "@/sections/Bento.astro";
import "@/styles/global.css";

import { getLocaleFromPath, t } from "../../lib/i18n";

const locale = getLocaleFromPath(Astro.url.pathname);
const copy = t(locale);
---

<Layout copy={copy}>
  <Hero copy={copy.hero} />
  <Bento copy={copy.bento} />
  <WorkExperience copy={copy.workExperience} locale={locale} />
  <AboutMe copy={copy.aboutMe} locale={locale} />
</Layout>
