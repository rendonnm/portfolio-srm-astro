---
import { Navbar } from "@/components/Navbar";

const { copy } = Astro.props;

const navItems = [
  { id: "init", name: copy.nav.init, href: "#" },
  { id: "experience", name: copy.nav.experience, href: "#experience" },
  { id: "about-me", name: copy.nav.aboutMe, href: "#about-me" },
];
---

<header class="fixed z-99 top-0 flex w-full justify-center py-4">
  <Navbar navItems={navItems} client:only="react" />
</header>
